{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "arcs.approval.v1",
  "type": "object",
  "required": ["target_option", "policy_ref", "decision", "reason", "actor", "timestamp"],
  "properties": {
    "target_option": {
      "type": "object",
      "required": ["artifact_id", "version_id"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "version_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "policy_ref": {
      "type": "object",
      "required": ["artifact_id", "version_id"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "version_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "string",
      "enum": ["approve", "reject", "modify", "revoke"]
    },
    "reason": { "type": "string", "minLength": 1 },
    "actor": {
      "type": "object",
      "required": ["actor_type", "id"],
      "properties": {
        "actor_type": {
          "type": "string",
          "enum": ["human", "system", "model", "executor"]
        },
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
