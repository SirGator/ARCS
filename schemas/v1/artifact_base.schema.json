{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vera/artifact_base@v1",
  "type": "object",
  "required": [
    "artifact_id",
    "version_id",
    "version",
    "type",
    "schema_id",
    "created_at",
    "created_by",
    "trust",
    "payload"
  ],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "version_id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "type": { "type": "string", "minLength": 1 },
    "schema_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": {
      "type": "object",
      "required": ["actor_type", "id"],
      "properties": {
        "actor_type": {
          "type": "string",
          "enum": ["human", "system", "model", "executor"]
        },
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "trust": {
      "type": "object",
      "required": ["level", "source_class"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "source_class": {
          "type": "string",
          "enum": ["human", "system", "model", "external"]
        },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
