{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "arcs.artifact_base.v1",
  "type": "object",
  "required": [
    "artifact_id",
    "version_id",
    "version",
    "type",
    "schema_id",
    "schema_version",
    "created_at",
    "created_by",
    "source",
    "trust",
    "stream_key",
    "payload"
  ],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "version_id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "type": { "type": "string", "minLength": 1 },
    "schema_id": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "integer", "minimum": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": {
      "type": "object",
      "required": ["actor_type", "id"],
      "properties": {
        "actor_type": {
          "type": "string",
          "enum": ["human", "system", "model", "executor"]
        },
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["kind", "ref"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["chat", "file", "api", "sensor", "timer", "internal"]
        },
        "ref": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "trust": {
      "type": "object",
      "required": ["level", "source_class"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "source_class": {
          "type": "string",
          "enum": ["human", "system", "model", "external"]
        }
      },
      "additionalProperties": false
    },
    "stream_key": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "payload": { "type": "object" },
    "provenance": {
      "type": "object",
      "properties": {
        "parents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rules_applied": {
          "type": "array",
          "items": { "type": "string" }
        },
        "models_used": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "prompt_hash", "inputs", "temperature", "raw_output_hash"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "prompt_hash": { "type": "string", "minLength": 1 },
              "inputs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "temperature": { "type": "number" },
              "raw_output_hash": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "transform": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
