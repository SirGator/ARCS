{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "arcs.task.v1",
  "type": "object",
  "required": ["title"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "scope": { "type": "string" },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    }
  },
  "additionalProperties": false
}
