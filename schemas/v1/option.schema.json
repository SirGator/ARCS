{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vera/option@v1",
  "type": "object",
  "required": ["title", "steps", "requires_permissions"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requires_permissions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
