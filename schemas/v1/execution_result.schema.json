{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "arcs.execution_result.v1",
  "type": "object",
  "required": ["action_id", "status"],
  "properties": {
    "action_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["success", "fail", "timeout", "cancelled"]
    },
    "output": { "type": "string" }
  },
  "additionalProperties": false
}
