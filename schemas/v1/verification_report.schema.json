{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "arcs.verification_report.v1",
  "type": "object",
  "required": ["target", "status"],
  "properties": {
    "target": {
      "type": "object",
      "required": ["artifact_id", "version_id"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "version_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "unknown"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "unknown"]
          },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
